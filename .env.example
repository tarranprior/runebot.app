# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=<API_KEY>"

# Server-only bearer token used by website SSR to fetch /logs.
# Must match the backend/internal API token (RUNEBOT_INTERNAL_API_TOKEN).
RUNEBOT_LOGS_API_TOKEN="<LOCAL_DEVELOPMENT_TOKEN>"
RUNEBOT_LOGS_API_URL="http://127.0.0.1:8080/logs"
# Optional override for sessions endpoint. If omitted, /sessions is derived from RUNEBOT_LOGS_API_URL.
# RUNEBOT_LOGS_SESSIONS_API_URL="http://127.0.0.1:8080/logs/sessions"

# Discord OAuth with JWT sessions (Auth.js v5)
AUTH_SECRET=""

# Base URL used by Auth.js to build redirect URIs.
# Must match the origin registered in the Discord OAuth app.
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Discord OAuth application credentials.
# Create an app at: https://discord.com/developers/applications
# Add redirect URI: http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Comma-separated Discord snowflake user IDs allowed to access /admin/*.
ADMIN_DISCORD_IDS=""

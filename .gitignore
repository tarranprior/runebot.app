# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# editor
.vscode/settings.json

# next.js
/.next/
/out/
/.source/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# vercel / netlify
.vercel
.netlify

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/app/generated/prisma
/src/generated/prisma
/prisma/generated

# artifacts
.artifacts/**

# local-only docs authoring examples (kitchen sink, scratch pages)
/content/docs/_scratch/
